{
  "name": "noir-frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "node scripts/dev.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:api": "node scripts/generate-api-types.mjs",
    "generate:api:file": "node scripts/generate-api-types.mjs --from-file",
    "generate:validation": "node scripts/generate-validation-schemas.mjs",
    "i18n:scan": "node scripts/scan-ui-strings.mjs",
    "visual:test": "cd e2e-tests && pnpm exec playwright test tests/visual",
    "visual:update": "cd e2e-tests && pnpm exec playwright test tests/visual --update-snapshots",
    "e2e": "cd e2e && npx playwright test",
    "e2e:smoke": "cd e2e && npx playwright test --grep @smoke",
    "e2e:regression": "cd e2e && npx playwright test --grep \"@smoke|@regression\"",
    "e2e:ui": "cd e2e && npx playwright test --ui",
    "e2e:debug": "cd e2e && npx playwright test --debug",
    "e2e:report": "cd e2e && npx playwright show-report",
    "e2e:codegen": "cd e2e && npx playwright codegen http://localhost:3000",
    "audit": "cd e2e && npx playwright test --project=ui-audit --project=ui-audit-platform",
    "audit:pages": "cd e2e && npx playwright test --project=ui-audit --project=ui-audit-platform",
    "audit:storybook": "cd e2e && npx playwright test --project=ui-audit --grep storybook",
    "audit:report": "node -e \"require('fs').readFileSync('../../../.ui-audit/summary.md','utf8').split('\\n').forEach(l=>console.log(l))\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "test:unit": "vitest run",
    "test:all": "vitest run && vitest run --config vitest.storybook.config.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-query-devtools": "^5.96.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tippyjs/react": "^4.2.6",
    "@tiptap/extension-character-count": "^3.22.1",
    "@tiptap/extension-color": "^3.22.1",
    "@tiptap/extension-highlight": "^3.22.1",
    "@tiptap/extension-image": "^3.22.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/extension-table": "^3.22.1",
    "@tiptap/extension-table-cell": "^3.22.1",
    "@tiptap/extension-table-header": "^3.22.1",
    "@tiptap/extension-table-row": "^3.22.1",
